[project]
name = "{{ package_name }}"
dynamic = ["version"]
description = ""
{%- if python == 'root' %}
readme = "README.md"
{%- endif %}
requires-python = ">={{ python_version }}"
{% if license == 'mit' %}
license = "MIT"
{% elif license == 'agpl' %}
license = "AGPL-3.0-or-later"
{% endif %}
{% if author_name %}
authors = [{ name = "{{ author_name }}" }]
{% endif %}
dependencies = []

[dependency-groups]
dev = [
  "coverage[toml]",
  "detect-secrets",
  "git-cliff",
  "pytest>=9.0.0",
  "pytest-cov",
  "pytest-randomly",
  "ruff>=0.8",
  "pyright",
{% if hooks != 'none' %}
  "pre-commit",
{% endif %}
]

[build-system]
requires = ["hatchling", "hatch-vcs"]
build-backend = "hatchling.build"

[tool.hatch.version]
source = "vcs"
fallback-version = "0.0.0"

[tool.uv]
cache-dir = "./.cache/uv"

[tool.hatch.build.targets.wheel]
packages = ["src/{{ package_name }}"]

[tool.pytest.ini_options]
addopts = ["--color=yes", "-x", "--failed-first", "--strict-markers", "--strict-config"]
testpaths = ["tests"]
pythonpath = ["src"]

[tool.coverage]
run.source = ["src"]
run.branch = true
report.exclude_lines = ["pragma: no cover", "if TYPE_CHECKING:"]
report.fail_under = 80
report.skip_covered = true
report.precision = 1
html.directory = "htmlcov"

[tool.ruff]
line-length = 100
src = ["src", "tests"]
lint.select = ["ALL"]
lint.extend-safe-fixes = ["TC001", "TC002", "TC003", "TC004"]
lint.future-annotations = true
lint.ignore = [
  "CPY",    # missing copyright notice
  "G004",   # f-strings in log messages
  "FIX",    # presence of fixme/todo markers
  "TD",     # todo formatting
  "EM",     # error message string formatting
  "DOC",    # pydoclint
  "D",      # pydocstyle
  "TRY003", # long exception messages
  # conflicting with ruff formatter — https://docs.astral.sh/ruff/formatter/#conflicting-lint-rules
  "W191", "E111", "E114", "E117", "D206", "D300",
  "Q000", "Q001", "Q002", "Q003", "COM812", "COM819",
]
lint.per-file-ignores = { "tests/**/*.py" = [
  "INP001",  # missing __init__.py
  "ARG002",  # unused method argument (fixtures)
  "S101",    # asserts allowed in tests
  "SLF001",  # private member access
  "PLR2004", # magic values in comparisons
] }
lint.flake8-type-checking.runtime-evaluated-base-classes = [
  "pydantic.BaseModel",
]
lint.pylint.max-args = 7

[tool.pyright]
include = ["src", "tests"]
ignore = ["**/__pycache__", ".venv"]
typeCheckingMode = "strict"
executionEnvironments = [{root = "tests", reportPrivateUsage = "none"}]
pythonVersion = "{{ python_version }}"
pythonPlatform = "Linux"
venvPath = "."
venv = ".venv"
