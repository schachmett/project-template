{%- if python == 'component' %}
_UV := cd {{ component_dir }} && uv run
{%- elif python == 'root' %}
_UV := uv run
{%- endif %}
{% if python != 'none' %}
.PHONY: fix check{% if has_api %} up{% endif %}

fix:
	$(_UV) ruff format
	$(_UV) ruff check --fix

check:
	$(_UV) ruff format --check
	$(_UV) ruff check
	$(_UV) pyright
	$(_UV) pytest --cov --cov-report=term --cov-report=html
{%- else %}

.PHONY: check{% if has_api %} up{% endif %}

check:
{%- if hooks != 'none' %}
	pre-commit run --all-files
{%- else %}
	@echo "No checks configured — add project-specific targets here"
{%- endif %}
{%- endif %}
{%- if has_api %}

up:
	docker compose up
{%- endif %}
