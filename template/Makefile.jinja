{% if python == 'root' %}
_UV := uv run
_CD :=
{% elif python == 'component' %}
_UV := cd backend && uv run
_CD := cd backend &&
{% endif %}

{% if python != 'none' %}
.PHONY: fmt fmt-check lint lint-fix typecheck test test-cov fix check{% if has_api %} up{% endif %}

fmt:
	$(_UV) ruff format

fmt-check:
	$(_UV) ruff format --check

lint:
	$(_UV) ruff check

lint-fix:
	$(_UV) ruff check --fix

typecheck:
	$(_UV) pyright

test:
	$(_UV) pytest

test-cov:
	$(_UV) pytest --cov --cov-report=term --cov-report=html

fix: fmt lint-fix

check: fmt-check lint typecheck test-cov
{% else %}
.PHONY: check{% if has_api %} up{% endif %}

check:
{% if hooks != 'none' %}
	pre-commit run --all-files
{% else %}
	@echo "No checks configured — add project-specific targets here"
{% endif %}
{% endif %}
{% if has_api %}

up:
	docker compose up
{% endif %}
