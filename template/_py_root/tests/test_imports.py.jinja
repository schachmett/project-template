"""Enforce architectural import boundaries via AST analysis."""

import ast
from pathlib import Path

import pytest

# Map each layer to the import prefixes it must never depend on.
# layer: path segment under src/{{ package_name }}/ (e.g. "db" → src/{{ package_name }}/db/)
# forbidden_prefix: dot-notation module prefix (e.g. "{{ package_name }}.cli")
# Example: ("db", "{{ package_name }}.cli") — db layer must not import from cli.
BOUNDARIES: list[tuple[str, str]] = []

_SRC = Path("{% if python == 'component' %}{{ component_dir }}/{% endif %}src/{{ package_name }}")


def _imports_of(path: Path) -> set[str]:
    tree = ast.parse(path.read_text())
    result: set[str] = set()
    for node in ast.walk(tree):
        match node:
            case ast.Import():
                result.update(alias.name for alias in node.names)
            case ast.ImportFrom() if node.module:
                result.add(node.module)
    return result


def _all_imports_in(directory: Path) -> set[str]:
    return {imp for path in directory.rglob("*.py") for imp in _imports_of(path)}


@pytest.mark.parametrize("layer,forbidden_prefix", BOUNDARIES)
def test_layer_boundary(layer: str, forbidden_prefix: str) -> None:
    violations = {m for m in _all_imports_in(_SRC / layer) if m.startswith(forbidden_prefix)}
    assert not violations, f"{layer!r} imports {forbidden_prefix!r}: {violations}"
