{%- if python == 'component' %}
# Auto-format and fix imports
fix:
    cd {{ component_dir }} && uv run ruff format
    cd {{ component_dir }} && uv run ruff check --fix

# Format check + ruff lint (no typecheck)
lint:
    cd {{ component_dir }} && uv run ruff format --check
    cd {{ component_dir }} && uv run ruff check

# Type checking
typecheck:
    cd {{ component_dir }} && uv run pyright

# Run tests with coverage
test:
    cd {{ component_dir }} && uv run pytest --cov --cov-report=term --cov-report=html

# Static analysis: lint + typecheck, no tests
static: lint typecheck

# Full CI suite
check: static test
{%- elif python == 'root' %}
# Auto-format and fix imports
fix:
    uv run ruff format
    uv run ruff check --fix

# Format check + ruff lint (no typecheck)
lint:
    uv run ruff format --check
    uv run ruff check

# Type checking
typecheck:
    uv run pyright

# Run tests with coverage
test:
    uv run pytest --cov --cov-report=term --cov-report=html

# Static analysis: lint + typecheck, no tests
static: lint typecheck

# Full CI suite
check: static test
{%- else %}
# Project-specific checks
check:
{%- if hooks != 'none' %}
    pre-commit run --all-files
{%- else %}
    @echo "No checks configured — add project-specific recipes here"
{%- endif %}
{%- endif %}
{%- if is_service %}

# Start the local docker compose stack
up:
    docker compose up
{%- endif %}
